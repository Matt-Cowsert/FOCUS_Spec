{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCR Schema with Stage 2 Enhancements",
  "type": "object",
  "properties": {
    "SCRDetails": {
      "type": "object",
      "description": "Metadata about the SCR version and general properties.",
      "properties": {
        "Version": {
          "type": "string"
        }
      },
      "required": [
        "Version"
      ],
      "additionalProperties": false
    },
    "PreConditions": {
      "type": "object",
      "description": "A dictionary of precondition flags used to determine rule applicability.",
      "patternProperties": {
        "^[A-Z0-9_]+$": {
          "type": "object",
          "properties": {
            "Description": {
              "type": "string"
            }
          },
          "required": [
            "Description"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "Attributes": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z0-9]+-A-\\d{3}-[MOC]$": {
          "type": "object",
          "properties": {
            "Rules": {
              "type": "object",
              "properties": {
                "Operator": {
                  "type": "string"
                },
                "Items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "Operator",
                "Items"
              ]
            }
          },
          "required": [
            "Rules"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "AttributeChecks": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z0-9]+-A-\\d{3}-[MOC]$": {
          "type": "object",
          "properties": {
            "Function": {
              "type": "string"
            },
            "Reference": {
              "type": "string"
            },
            "Notes": {
              "type": "string"
            },
            "VersionIntroduced": {
              "type": "string"
            },
            "Status": {
              "type": "string"
            },
            "ValidationCriteria": {
              "type": "object",
              "properties": {
                "mustSatisfy": {
                  "type": "string"
                }
              },
              "required": [
                "mustSatisfy"
              ],
              "additionalProperties": true
            }
          },
          "required": [
            "Function",
            "Reference",
            "VersionIntroduced",
            "Status",
            "ValidationCriteria"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "CheckFunction": {
      "type": "object",
      "description": "Reusable check functions used in validation logic (e.g., AND, OR, ColumnPresent).",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "type": "object",
          "properties": {
            "Description": {
              "type": "string"
            },
            "Arguments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "FormatAttributes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "Description",
            "Arguments",
            "FormatAttributes"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ConformanceTables": {
      "type": "object",
      "description": "Top-level groupings (like FOCUS) mapping to sets of rule IDs.",
      "patternProperties": {
        "^[A-Z0-9_]+$": {
          "type": "object",
          "properties": {
            "ConformanceRules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "ConformanceRules"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ConformanceRules": {
      "type": "object",
      "description": "The list of all rules, each containing logic, reference metadata, and criteria.",
      "items": {
        "type": "object",
        "patternProperties": {
          "^[A-Za-z0-9]+-C-\\d{3}-[MOC]$": {
            "type": "object",
            "properties": {
              "Function": {
                "type": "string",
                "enum": [
                  "Format",
                  "Presence",
                  "Validation",
                  "Type",
                  "Composite"
                ]
              },
              "Reference": {
                "type": "string"
              },
              "Notes": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "VersionIntroduced": {
                "type": "string"
              },
              "Status": {
                "type": "string",
                "enum": [
                  "active",
                  "deprecated"
                ]
              },
              "PreConditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "CheckType": {
                "type": "string",
                "enum": [
                  "static",
                  "dynamic"
                ]
              },
              "ValidationCriteria": {
                "type": "object",
                "properties": {
                  "mustSatisfy": {
                    "type": "string"
                  },
                  "Check": {
                    "type": [
                      "object",
                      "null"
                    ]
                  },
                  "Condition": {
                    "type": [
                      "object",
                      "null"
                    ]
                  }
                },
                "required": [
                  "mustSatisfy"
                ],
                "additionalProperties": true
              }
            },
            "required": [
              "Function",
              "Reference",
              "VersionIntroduced",
              "Status",
              "PreConditions",
              "CheckType",
              "ValidationCriteria"
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": [
    "SCRDetails",
    "PreConditions",
    "Attributes",
    "AttributeChecks",
    "CheckFunction",
    "ConformanceTables",
    "ConformanceRules"
  ],
  "additionalProperties": false
}