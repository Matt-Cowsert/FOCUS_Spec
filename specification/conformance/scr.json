    {
      "ListUnitPrice-C-001-C": {
        "Function": "Define presence in dataset",
        "Reference": "ListUnitPrice",
        "Notes": "",
        "VersionIntroduced": "1.0",
        "Status": "active",
        "PreConditions": [
          "PUBLIC_PRICE_LIST_SUPPORTED"
        ],
        "CheckType": "Static",
        "ValidationCriteria": {
          "mustSatisfy": "MUST be present in a FOCUS dataset when the provider publishes unit prices exclusive of discounts",
          "Check": {
            "CheckFunction": "ColumnPresent",
            "ColumnName": "ListUnitPrice"
          },
          "Condition": null
        }
      },
      "ListUnitPrice-C-002-M": {
        "Function": "Specify data type",
        "Reference": "ListUnitPrice",
        "Notes": "",
        "VersionIntroduced": "1.0",
        "Status": "active",
        "PreConditions": [
          "PUBLIC_PRICE_LIST_SUPPORTED"
        ],
        "CheckType": "Static",
        "ValidationCriteria": {
          "mustSatisfy": "MUST be of type Decimal",
          "Check": {
            "CheckFunction": "TypeDecimal",
            "ColumnName": "ListUnitPrice"
          },
          "Condition": null
        }
      },
      "ListUnitPrice-C-003-M": {
